# Google Ads API Credentials
# Ersetze die Dummy-Werte mit deinen echten Zugangsdaten.
# Siehe: https://developers.google.com/google-ads/api/docs/client-libs/python/configuration

developer_token: "YOUR_DEVELOPER_TOKEN"
client_id: "YOUR_CLIENT_ID"
client_secret: "YOUR_CLIENT_SECRET"
refresh_token: "YOUR_REFRESH_TOKEN"
login_customer_id: "YOUR_MCC_ID"  # Optional: Deine MCC Account ID (Verwalterkonto)
use_proto_plus: True
